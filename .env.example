# Vercel环境变量配置示例
# 在Vercel控制台的Settings > Environment Variables中添加以下变量：

# 环境配置
NODE_ENV=production

# 数据库配置 (开发环境 - dev分支 - 过期时间: Apr 4, 2026 3:16 pm GMT+8)
DATABASE_URL_DEV=postgresql://username:password@ep-your-region.neon.tech/your-database?sslmode=require&channel_binding=require
DATABASE_URL_UNPOOLED_DEV=postgresql://username:password@ep-your-region.neon.tech/your-database?sslmode=require
PGHOST_DEV=ep-your-region.neon.tech
PGHOST_UNPOOLED_DEV=ep-your-region.neon.tech

# 数据库配置 (生产环境 - main分支)
DATABASE_URL_PROD=postgresql://username:password@ep-your-region.neon.tech/your-database?channel_binding=require&sslmode=require
DATABASE_URL_UNPOOLED_PROD=postgresql://username:password@ep-your-region.neon.tech/your-database?sslmode=require
PGHOST_PROD=ep-your-region.neon.tech
PGHOST_UNPOOLED_PROD=ep-your-region.neon.tech

# 用户配置 (格式: username:password:display_name;username:password:display_name)
USERS_CONFIG=admin:your_password:Admin;user:your_password:User

# JWT密钥（必须设置！生产环境请使用强随机字符串）
# 生成命令: node -e "console.log('JWT_SECRET=' + require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-change-this-in-production

# 数据库连接参数
PGHOST=ep-your-region.neon.tech
PGHOST_PROD=ep-your-region.neon.tech
PGHOST_UNPOOLED_PROD=ep-your-region.neon.tech
PGUSER=your-username
PGDATABASE=your-database
PGPASSWORD=your-password

# Vercel Postgres Templates (开发环境 - dev分支 - 过期时间: Apr 4, 2026 3:16 pm GMT+8)
POSTGRES_URL=${DATABASE_URL_DEV}
POSTGRES_URL_NON_POOLING=${DATABASE_URL_UNPOOLED_DEV}
POSTGRES_USER=your-username
POSTGRES_HOST=${PGHOST_DEV}
POSTGRES_PASSWORD=your-password
POSTGRES_DATABASE=your-database
POSTGRES_URL_NO_SSL=postgresql://username:password@ep-your-region.neon.tech/your-database
POSTGRES_PRISMA_URL=postgresql://username:password@ep-your-region.neon.tech/your-database?channel_binding=require&connect_timeout=15&sslmode=require